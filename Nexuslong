# Nexuslong
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Nexus WMS | Oficial</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --primary: #ff6b00; --dark: #1a1a1f; --bg: #f4f7f6; --success: #22c55e; --danger: #ef4444; --warning: #facc15; }
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }
        body { background: var(--bg); display: flex; height: 100vh; width: 100vw; overflow: hidden; }

        /* LOGIN */
        #login-screen { position: fixed; inset: 0; background: var(--dark); z-index: 10000; display: flex; align-items: center; justify-content: center; }
        .login-card { background: white; padding: 35px; border-radius: 20px; width: 95%; max-width: 360px; text-align: center; }
        
        /* SIDEBAR */
        .sidebar { width: 260px; background: var(--dark); color: white; display: flex; flex-direction: column; transition: 0.3s; z-index: 999; }
        .sidebar-brand { padding: 25px; background: var(--primary); font-weight: 800; text-align: center; font-size: 1.2rem; }
        .sidebar ul { list-style: none; padding: 10px; flex: 1; }
        .sidebar button { width: 100%; padding: 14px; background: transparent; border: none; color: #a4a4b2; text-align: left; cursor: pointer; border-radius: 10px; margin-bottom: 5px; display: flex; align-items: center; gap: 12px; font-size: 14px; }
        .sidebar button.active { background: var(--primary); color: white; font-weight: bold; }
        .btn-logout { color: #ff4d4d !important; border-top: 1px solid #333 !important; padding: 20px !important; text-align: center; cursor: pointer; }

        /* CONTEÚDO */
        .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; width: 100%; }
        .top-bar { padding: 15px; background: white; border-bottom: 1px solid #ddd; display: flex; justify-content: space-between; align-items: center; }
        .content { padding: 20px; overflow-y: auto; flex: 1; }
        .card { background: white; padding: 20px; border-radius: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); margin-bottom: 20px; }
        
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 15px; }
        label { display: block; font-size: 11px; font-weight: 700; color: #666; margin-bottom: 5px; text-transform: uppercase; }
        input, select { padding: 12px; border: 1.5px solid #ddd; border-radius: 10px; width: 100%; outline: none; font-size: 14px; background: white; }
        .btn-orange { background: var(--primary); color: white; border: none; padding: 15px; border-radius: 10px; cursor: pointer; font-weight: 700; width: 100%; transition: 0.2s; }
        
        table { width: 100%; border-collapse: collapse; min-width: 400px; }
        th { text-align: left; padding: 12px; background: #fff4ed; color: var(--primary); font-size: 11px; text-transform: uppercase; }
        td { padding: 12px; border-bottom: 1px solid #eee; font-size: 13px; }

        @media (max-width: 1024px) {
            .sidebar { position: fixed; left: -260px; height: 100%; }
            .sidebar.mobile-open { left: 0; }
        }
    </style>
</head>
<body>

    <div id="login-screen">
        <div class="login-card">
            <h2 style="color:var(--primary); margin-bottom:10px">NEXUS WMS</h2>
            <input type="text" id="user-in" placeholder="Usuário">
            <input type="password" id="pass-in" placeholder="Senha">
            <button class="btn-orange" onclick="execLogin()">ENTRAR</button>
        </div>
    </div>

    <nav class="sidebar" id="sidebar">
        <div class="sidebar-brand">NEXUS WMS</div>
        <ul id="nav-menu">
            <li><button class="active" onclick="tab('dash', this)"><i class="fas fa-home"></i> Início</button></li>
            <li><button onclick="tab('cad', this)"><i class="fas fa-plus-circle"></i> Cadastro</button></li>
            <li><button onclick="tab('saida', this)"><i class="fas fa-sign-out-alt"></i> Saída</button></li>
            <li><button onclick="tab('extrato', this)"><i class="fas fa-history"></i> Extrato</button></li>
            <li><button onclick="tab('estoque', this)"><i class="fas fa-warehouse"></i> Estoque</button></li>
            <li><button onclick="tab('admin', this)"><i class="fas fa-user-shield"></i> ADM</button></li>
        </ul>
        <div class="btn-logout" onclick="location.reload()">SAIR</div>
    </nav>

    <div class="main">
        <header class="top-bar">
            <button onclick="document.getElementById('sidebar').classList.toggle('mobile-open')" style="border:none; background:none; font-size:20px; color: var(--primary);"><i class="fas fa-bars"></i></button>
            <div style="font-weight: 800; color: var(--primary);">NEXUS ACTIVE</div>
        </header>

        <div class="content">
            <section id="dash" class="tab-content">
                <div class="grid">
                    <div class="card"><label>Total Itens</label><h2 id="h-total-qtd">0</h2></div>
                    <div class="card"><label>Patrimônio</label><h2 id="h-total-val">R$ 0,00</h2></div>
                </div>
                <div class="card">
                    <h3>Resumo de Saldo</h3>
                    <div style="overflow-x:auto"><table><thead><tr><th>ITEM</th><th>QTD</th></tr></thead><tbody id="home-corpo"></tbody></table></div>
                </section>

            <section id="cad" class="tab-content" style="display:none">
                <div class="card">
                    <h3>Cadastro</h3>
                    <div class="grid">
                        <div><label>Nome</label><input type="text" id="c-nome" placeholder="Nome"></div>
                        <div><label>Quantidade</label><input type="number" id="c-qtd" placeholder="Qtd"></div>
                        <div><label>Valor Unit.</label><input type="number" id="c-valor" placeholder="Valor Unit."></div>
                        <div><label>Validade</label><input type="date" id="c-val"></div>
                    </div>
                    <button class="btn-orange" onclick="salvarProduto()">SALVAR NO ESTOQUE</button>
                </div>
            </section>

            <section id="saida" class="tab-content" style="display:none">
                <div class="card">
                    <h3>Saída</h3>
                    <div class="grid">
                        <div><label>Selecionar Objeto</label><select id="s-sel"></select></div>
                        <div><label>Quantidade</label><input type="number" id="s-qtd" placeholder="0"></div>
                        <div><label>Solicitante</label><input type="text" id="s-nome-sol" placeholder="Nome"></div>
                        <div><label>Destino</label><input type="text" id="s-dest" placeholder="Destino"></div>
                    </div>
                    <button class="btn-orange" onclick="darBaixa()">CONFIRMAR BAIXA</button>
                </div>
            </section>

            <section id="extrato" class="tab-content" style="display:none">
                <div class="card">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                        <h3>Histórico</h3>
                        <button onclick="limparExtrato()" style="background: var(--danger); color: white; border: none; padding: 8px 15px; border-radius: 8px; cursor: pointer; font-size: 12px; font-weight: bold;">LIMPAR HISTÓRICO</button>
                    </div>
                    <div style="overflow-x:auto"><table><thead><tr><th>DATA</th><th>TIPO</th><th>ITEM</th><th>QTD</th><th>DESTINO</th><th>SOLICITANTE</th></tr></thead><tbody id="t-extrato"></tbody></table></div>
                </div>
            </section>

            <section id="estoque" class="tab-content" style="display:none">
                <div class="card">
                    <div style="overflow-x:auto">
                        <table>
                            <thead><tr><th>NOME</th><th>QTD</th><th>VALOR</th><th>AÇÕES</th></tr></thead>
                            <tbody id="t-corpo"></tbody>
                        </table>
                    </div>
                </div>
            </section>

            <section id="admin" class="tab-content" style="display:none">
                <div class="card" style="background: #e7f3ff; border: 1px solid #2196f3;">
                    <h3><i class="fas fa-file-export"></i> Backup de Segurança</h3>
                    <p style="font-size: 12px; margin-bottom: 10px;">Exportar dados para jonasmarques850@gmail.com</p>
                    <button class="btn-orange" onclick="exportBackup()" style="background: #2196f3;">EXPORTAR AGORA (.JSON)</button>
                </div>

                <div class="card">
                    <h3>Gestão de Usuários e Políticas</h3>
                    <div class="grid">
                        <input type="text" id="a-user" placeholder="Login">
                        <input type="password" id="a-pass" placeholder="Senha">
                    </div>
                    <div class="grid" style="font-size: 11px">
                        <label><input type="checkbox" class="p-check" value="cad"> Cadastro</label>
                        <label><input type="checkbox" class="p-check" value="saida"> Saída</label>
                        <label><input type="checkbox" class="p-check" value="extrato"> Extrato</label>
                        <label><input type="checkbox" class="p-check" value="estoque"> Estoque</label>
                        <label><input type="checkbox" class="p-check" value="admin"> ADM</label>
                    </div>
                    <button class="btn-orange" onclick="criarUsuario()">CRIAR USUÁRIO</button>
                </div>
                <div id="u-corpo-adm"></div>
            </section>
        </div>
    </div>

    <script>
        let dbP = JSON.parse(localStorage.getItem('nx_p')) || [];
        let dbU = JSON.parse(localStorage.getItem('nx_u')) || [{u:'admin', s:'1', p:['dash','cad','saida','extrato','estoque','admin']}];
        let dbE = JSON.parse(localStorage.getItem('nx_ext')) || [];

        function execLogin() {
            const u = document.getElementById('user-in').value.trim().toLowerCase();
            const s = document.getElementById('pass-in').value;
            const found = dbU.find(x => x.u === u && x.s === s);
            if(found) { document.getElementById('login-screen').style.display='none'; render(); }
            else alert("Erro!");
        }

        // --- MOTOR DE ALTERAÇÃO (PEDIDO) ---
        function confirmarAlteracao(i) {
            const n = prompt("Novo Nome:", dbP[i].nome);
            if (n === null) return;
            const q = prompt("Nova Quantidade:", dbP[i].qtd);
            if (q === null) return;
            const v = prompt("Novo Valor:", dbP[i].valor);
            if (v === null) return;

            dbP[i].nome = n;
            dbP[i].qtd = parseInt(q) || 0;
            dbP[i].valor = parseFloat(v) || 0;
            save();
            alert("Objeto alterado com sucesso!");
        }

        function salvarProduto() {
            const n = document.getElementById('c-nome').value.trim();
            const q = parseInt(document.getElementById('c-qtd').value) || 0;
            if(!n) return;
            dbP.push({ nome: n, qtd: q, valor: parseFloat(document.getElementById('c-valor').value)||0, val: document.getElementById('c-val').value });
            dbE.unshift({ data: new Date().toLocaleString(), tipo: 'ENTRADA', item: n, qtd: q, dest: 'ESTOQUE', user: 'SISTEMA' });
            save();
            alert("Salvo!");
            document.querySelectorAll('#cad input').forEach(i => i.value = "");
        }

        function darBaixa() {
            const n = document.getElementById('s-sel').value;
            const q = parseInt(document.getElementById('s-qtd').value) || 0;
            const idx = dbP.findIndex(x => x.nome === n);
            if(idx !== -1) {
                const saldo = Number(dbP[idx].qtd);
                if(saldo >= q && q > 0) {
                    dbP[idx].qtd = saldo - q;
                    dbE.unshift({ data: new Date().toLocaleString(), tipo: 'SAÍDA', item: n, qtd: q, dest: document.getElementById('s-dest').value, user: document.getElementById('s-nome-sol').value });
                    save(); alert("Baixa Realizada!");
                } else alert("Saldo insuficiente!");
            }
        }

        function limparExtrato() { if(confirm("Apagar histórico?")) { dbE = []; save(); } }

        function exportBackup() {
            const data = { estoque: dbP, usuarios: dbU, historico: dbE };
            const blob = new Blob([JSON.stringify(data, null, 2)], {type: 'application/json'});
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = `Backup_Nexus_${new Date().toLocaleDateString()}.json`;
            a.click();
        }

        function criarUsuario() {
            const u = document.getElementById('a-user').value.toLowerCase().trim();
            const s = document.getElementById('a-pass').value;
            if(!u || !s) return;
            const p = ['dash', ...Array.from(document.querySelectorAll('.p-check:checked')).map(c => c.value)];
            dbU.push({u, s, p});
            localStorage.setItem('nx_u', JSON.stringify(dbU));
            render();
        }

        function save() { localStorage.setItem('nx_p', JSON.stringify(dbP)); localStorage.setItem('nx_ext', JSON.stringify(dbE)); render(); }

        function render() {
            document.getElementById('h-total-qtd').innerText = dbP.reduce((a,b) => a + Number(b.qtd), 0);
            document.getElementById('h-total-val').innerText = "R$ " + dbP.reduce((a,b) => a + (b.qtd * b.valor), 0).toFixed(2);
            document.getElementById('home-corpo').innerHTML = dbP.map(p => `<tr><td>${p.nome}</td><td>${p.qtd}</td></tr>`).join('');
            
            // TABELA ESTOQUE COM BOTAO DE ALTERAR (LÁPIS) E EXCLUIR (LIXEIRA)
            document.getElementById('t-corpo').innerHTML = dbP.map((p, i) => `<tr><td>${p.nome}</td><td>${p.qtd}</td><td>R$ ${p.valor}</td><td>
                <button onclick="confirmarAlteracao(${i})" style="color:blue;border:none;background:none;margin-right:10px"><i class="fas fa-edit"></i></button>
                <button onclick="dbP.splice(${i},1);save()" style="color:red;border:none;background:none"><i class="fas fa-trash"></i></button>
            </td></tr>`).join('');
            
            document.getElementById('s-sel').innerHTML = '<option value="">Item...</option>' + dbP.map(p => `<option value="${p.nome}">${p.nome}</option>`).join('');
            document.getElementById('t-extrato').innerHTML = dbE.map(e => `<tr><td>${e.data}</td><td>${e.tipo}</td><td>${e.item}</td><td>${e.qtd}</td><td>${e.dest}</td><td>${e.user}</td></tr>`).join('');
            document.getElementById('u-corpo-adm').innerHTML = dbU.map((u, i) => `<div class="card" style="padding:10px; display:flex; justify-content:space-between"><span>${u.u}</span> <button onclick="if('${u.u}'!='admin'){dbU.splice(${i},1);localStorage.setItem('nx_u',JSON.stringify(dbU));render();}" style="color:red;border:none;background:none">X</button></div>`).join('');
        }

        function tab(id, btn) {
            document.querySelectorAll('.tab-content').forEach(t => t.style.display = 'none');
            document.getElementById(id).style.display = 'block';
            document.querySelectorAll('.sidebar button').forEach(b => b.classList.remove('active'));
            if(btn) btn.classList.add('active');
            if (window.innerWidth <= 1024) document.getElementById('sidebar').classList.remove('mobile-open');
            render();
        }

        window.onload = render;
    </script>
</body>
</html>
            
